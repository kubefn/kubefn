FROM node:21-slim

WORKDIR /opt/kubefn

COPY src/ src/
COPY package.json .
COPY examples/ /var/kubefn/functions/

ENV KUBEFN_PORT=8080
ENV KUBEFN_FUNCTIONS_DIR=/var/kubefn/functions

EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=3s --retries=3 \
    CMD node -e "fetch('http://localhost:8080/admin/health').then(r => process.exit(r.ok ? 0 : 1)).catch(() => process.exit(1))" || exit 1

ENTRYPOINT ["node", "src/index.js", "--port", "8080", "--functions-dir", "/var/kubefn/functions"]
